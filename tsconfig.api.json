{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".vercel/output",
    "rootDir": "api",
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["api"]
}
